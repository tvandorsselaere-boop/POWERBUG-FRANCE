# ===========================================
# PowerBug France — Variables d'environnement
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Supabase (partagé avec Golf-Shop) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# --- Stripe ---
# TEST : pk_test_... / sk_test_... (compte Tom)
# LIVE : pk_live_... / sk_live_... (compte Fred)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- ZeptoMail (emails transactionnels) ---
ZEPTO_API_KEY=Zoho-enczapikey_xxx

# --- Emails ---
EMAIL_FROM=commandes@powerbug.fr
EMAIL_REPLY_TO=commandes@powerbug.fr
EMAIL_ORDERS_TO=commandes@powerbug.fr
EMAIL_STOCK_ALERT_TO=commandes@powerbug.fr
ADMIN_EMAIL=thomas@facile-ia.fr

# --- Google OAuth ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://powerbug.fr
NEXT_PUBLIC_STORE_ID=powerbug

# --- Admin ---
# Emails autorisés pour l'admin (séparés par des virgules)
ADMIN_EMAILS=thomas@facile-ia.fr
